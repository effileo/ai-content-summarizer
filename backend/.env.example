# ─── Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the actual .env file (it contains secrets!)
# The .env.example file is safe to commit as a template.

GOOGLE_API_KEY=your_gemini_api_key_here

# Supabase PostgreSQL connection string
# Find this in: Supabase Dashboard → Settings → Database → Connection string (URI)
# Replace postgresql:// with postgresql+asyncpg:// in the URI
DATABASE_URL=postgresql+asyncpg://postgres:<password>@<host>:5432/postgres
